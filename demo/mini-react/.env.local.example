# Auth0 application credentials — copy to .env.local and fill in your values
# Create a Single Page Application in Auth0 dashboard and set:
#   Allowed Callback URLs: http://localhost:3000/auth0
#   Allowed Logout URLs:   http://localhost:3000/auth0
#   Allowed Web Origins:   http://localhost:3000

NEXT_PUBLIC_AUTH0_DOMAIN=your-tenant.auth0.com
NEXT_PUBLIC_AUTH0_CLIENT_ID=your_client_id

# Optional: API audience (required for getAccessTokenSilently to return a JWT)
NEXT_PUBLIC_AUTH0_AUDIENCE=https://mini-guard-demo

# Optional: dot-notation path in the JWT payload where roles live.
# Auth0 roles are usually in a namespaced custom claim:
#   https://your-domain.com/roles
# Defaults to "roles" if not set.
NEXT_PUBLIC_AUTH0_ROLES_CLAIM=https://mini-guard-demo/roles
