{
  "name": "mini-guard",
  "version": "1.1.0",
  "description": "Ultra-lightweight (<1KB) zero-dependency frontend RBAC with JWT support",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    },
    "./angular": {
      "import": "./dist/angular.js",
      "types": "./dist/angular.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": false,
  "peerDependencies": {
    "@angular/core": ">=15",
    "react": ">=17"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "@angular/core": {
      "optional": true
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "link:setup": "npm run build && npm link",
    "build:check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "size:gz": "tsup && gzip -c dist/index.js | wc -c",
    "format": "biome format --write",
    "format:check": "biome format --diagnostic-level=error",
    "lint": "biome lint",
    "prepublishOnly": "npm run build:check && npm run format:check && npm run lint && npm run build && npm test"
  },
  "keywords": [
    "rbac",
    "jwt",
    "authorization",
    "permissions",
    "roles",
    "frontend",
    "zero-dependency",
    "tiny"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/trung-t-nguyen/mini-guard.git"
  },
  "author": "Trung Nguyen",
  "license": "MIT",
  "devDependencies": {
    "@angular/common": "^19.2.22",
    "@angular/compiler": "^19.2.22",
    "@angular/core": "^19.2.22",
    "@angular/platform-browser": "^19.2.22",
    "@biomejs/biome": "^2.4.15",
    "@testing-library/react": "^14.3.1",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom": "^29.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "zone.js": "^0.15.1"
  }
}
